rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return isSignedIn() && getUserRole() == 'superAdmin';
    }

    function isStationManager() {
      return isSignedIn() && (getUserRole() == 'superAdmin' || getUserRole() == 'stationManager');
    }

    function isBroadcaster() {
      return isSignedIn() && (getUserRole() in ['superAdmin', 'stationManager', 'broadcaster']);
    }

    function isAnyAdmin() {
      return isSignedIn() && (getUserRole() in ['superAdmin', 'stationManager', 'broadcaster', 'unnAdmin']);
    }

    function signedInOwnDoc(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function safeUserSelfUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'name', 'displayName', 'email', 'photoUrl',
        'notifyShowAlerts', 'notifyBreakingNews', 'notifyRequestConfirmation',
        'notifySpecialEvents', 'audioQuality', 'totalListeningMinutes',
        'episodesPlayed', 'topCategory', 'requestedPremiumUpgrade', 'updatedAt'
      ]) && !(request.resource.data.keys().hasAny(['role', 'isActive', 'isPremium', 'premiumSince', 'premiumReference']));
    }

    function safeAdCounterUpdate() {
      let diff = request.resource.data.diff(resource.data);
      return isSignedIn() && diff.affectedKeys().hasOnly(['impressions', 'clicks'])
        && (!diff.changedKeys().hasAny(['impressions']) || request.resource.data.impressions == resource.data.impressions + 1)
        && (!diff.changedKeys().hasAny(['clicks']) || request.resource.data.clicks == resource.data.clicks + 1);
    }

    function safeAnalyticsUpdate() {
      return isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'date', 'sessionStarts', 'totalListeningSeconds', 'uniqueListenersCount',
        'peakConcurrent', 'listeners', 'requests', 'podcastPlays',
        'premiumPurchases', 'eventTickets', 'platforms', 'location',
        'platformBreakdown', 'totalListeners', 'premiumUsers', 'concurrent'
      ]);
    }

    match /shows/{doc} {
      allow read: if true;
      allow write: if isStationManager();
    }

    match /episodes/{doc} {
      allow read: if true;
      allow write: if isBroadcaster();
    }

    match /news/{doc} {
      allow read: if true;
      allow write: if isStationManager();
    }

    match /stream_config/{doc} {
      allow read: if true;
      allow write: if isStationManager();
    }

    match /requests/{doc} {
      allow create: if isSignedIn()
        && request.resource.data.status == 'pending'
        && request.resource.data.type in ['song', 'showPitch', 'shoutout']
        && (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid);
      allow read: if isBroadcaster();
      allow update: if isBroadcaster()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'moderationNotes', 'assignedTo', 'updatedAt'
        ]);
      allow delete: if isStationManager();
    }

    match /users/{userId} {
      // Always allow reading own document — needed for role check on login
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow read: if isAnyAdmin();
      allow create: if isSuperAdmin() || (signedInOwnDoc(userId) && request.resource.data.keys().hasOnly([
        'name', 'displayName', 'email', 'photoUrl',
        'notifyShowAlerts', 'notifyBreakingNews', 'notifyRequestConfirmation',
        'notifySpecialEvents', 'audioQuality', 'totalListeningMinutes',
        'episodesPlayed', 'topCategory', 'requestedPremiumUpgrade', 'updatedAt'
      ]));
      allow update: if isSuperAdmin() || (signedInOwnDoc(userId) && safeUserSelfUpdate());
      allow delete: if isSuperAdmin();
    }

    match /revenue/{doc} {
      allow read: if isSignedIn() && (getUserRole() in ['superAdmin', 'unnAdmin']);
      allow write: if isSuperAdmin();
    }

    match /ads/{doc} {
      allow read: if true;
      // Station managers can do full writes; signed-in listeners can only increment counters
      allow write: if isStationManager();
      allow update: if safeAdCounterUpdate();
    }

    match /admin_config/{doc} {
      allow read: if doc == 'payments_public' || isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    match /analytics/{doc} {
      allow read: if isAnyAdmin();
      allow write: if safeAnalyticsUpdate();
    }

    match /admin_invites/{inviteId} {
      // Invited user can read their own invite (doc ID = their email)
      allow read: if isSignedIn() && inviteId == request.auth.token.email;
      allow read, write: if isSuperAdmin();
    }

    match /notification_queue/{doc} {
      allow create: if isStationManager();
      allow read, update: if isStationManager();
    }

    match /podcast_feeds/{doc} {
      allow read: if true;
      allow write: if isBroadcaster();
    }

    // Paid live events
    match /events/{doc} {
      allow read: if true;
      allow write: if isStationManager();
    }

    // Event tickets — written by Cloud Functions (admin SDK bypasses rules).
    // App reads its own ticket only.
    match /tickets/{ticketId} {
      allow read: if isSignedIn() && ticketId.matches(request.auth.uid + '_.*');
      allow write: if false; // Cloud Functions only
    }

    // Podcast episodes uploaded directly to Firestore
    match /podcasts/{doc} {
      allow read: if true;
      allow write: if isBroadcaster();
    }

    match /payment_attempts/{doc} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    match /admin_audit_logs/{doc} {
      allow read: if isAnyAdmin();
      allow write: if false;
    }

    match /mail/{doc} {
      allow create: if isSuperAdmin();
    }

    // ── Live Chat ────────────────────────────────────────────────────────────

    function isChatActive() {
      return get(/databases/$(database)/documents/chat_config/current).data.isActive == true;
    }

    function isNotBanned() {
      return !exists(/databases/$(database)/documents/banned_users/$(request.auth.uid));
    }

    match /chat_config/{doc} {
      allow read: if true;
      allow write: if isAnyAdmin();
    }

    match /chat_messages/{msgId} {
      allow read: if true;
      allow create: if isSignedIn()
        && isNotBanned()
        && isChatActive()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 300
        && request.resource.data.type in ['chat', 'song_request', 'pitch']
        && request.resource.data.isPinned == false
        && request.resource.data.isHidden == false;
      allow update: if isAnyAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isPinned', 'isHidden']);
      allow delete: if isAnyAdmin();
    }

    match /banned_users/{uid} {
      allow read: if isAnyAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow write: if isAnyAdmin();
    }
  }
}
