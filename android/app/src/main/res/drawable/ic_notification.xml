<?xml version="1.0" encoding="utf-8"?>
<!-- Monochrome notification icon — must be white/transparent only (Android system colours it) -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Radio wave arcs -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M1,12 A11,11 0 0,1 23,12"/>
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M4.5,12 A7.5,7.5 0 0,1 19.5,12"/>
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M8,12 A4,4 0 0,1 16,12"/>
    <!-- Centre dot -->
    <circle
        android:fillColor="#FFFFFF"
        android:cx="12"
        android:cy="12"
        android:r="1.5"/>
</vector>
